{
  "title": "vLLM Worker Comparison",
  "uid": "worker-comparison",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Per-worker request rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "amp" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "amp" },
          "expr": "sum by (pod)(rate(vllm:request_success_total[5m]))",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Per-worker TTFT p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "amp" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "amp" },
          "expr": "histogram_quantile(0.95, sum by (pod, le)(rate(vllm:time_to_first_token_seconds_bucket[5m])))",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "KV-cache utilisation per worker",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "amp" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "amp" },
          "expr": "vllm:kv_cache_usage_perc",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Prefix-cache hit rate per worker",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "amp" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "amp" },
          "expr": "rate(vllm:gpu_prefix_cache_hits_total[5m]) / clamp_min(rate(vllm:gpu_prefix_cache_queries_total[5m]), 1)",
          "legendFormat": "{{pod}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Queue depth per worker",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "amp" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "amp" },
          "expr": "vllm:num_requests_waiting",
          "legendFormat": "{{pod}}"
        }
      ]
    }
  ]
}
