{
  "title": "GPU Health",
  "uid": "gpu-health",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "GPU utilisation (%) per node",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "amp" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "amp" },
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "legendFormat": "{{Hostname}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "GPU memory used (GB) per node",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "amp" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "amp" },
          "expr": "DCGM_FI_DEV_FB_USED / 1024",
          "legendFormat": "{{Hostname}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "GPU temperature (°C) per node",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "amp" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "amp" },
          "expr": "DCGM_FI_DEV_GPU_TEMP",
          "legendFormat": "{{Hostname}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "GPU power draw (W) per node",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "amp" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "amp" },
          "expr": "DCGM_FI_DEV_POWER_USAGE",
          "legendFormat": "{{Hostname}}"
        }
      ]
    }
  ]
}
