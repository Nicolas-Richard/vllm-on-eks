{
  "title": "vLLM Inference Latency",
  "uid": "inference-latency",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "TTFT p50",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "amp" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "amp" },
          "expr": "histogram_quantile(0.50, sum by (le)(rate(vllm:time_to_first_token_seconds_bucket[5m])))",
          "legendFormat": "TTFT p50"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "TTFT p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "amp" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "amp" },
          "expr": "histogram_quantile(0.95, sum by (le)(rate(vllm:time_to_first_token_seconds_bucket[5m])))",
          "legendFormat": "TTFT p95"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Inter-token latency p95",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "amp" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "amp" },
          "expr": "histogram_quantile(0.95, sum by (le)(rate(vllm:inter_token_latency_seconds_bucket[5m])))",
          "legendFormat": "Inter-token latency p95"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "End-to-end latency p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "amp" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "amp" },
          "expr": "histogram_quantile(0.95, sum by (le)(rate(vllm:e2e_request_latency_seconds_bucket[5m])))",
          "legendFormat": "End-to-end latency p95"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Throughput (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "amp" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "amp" },
          "expr": "sum(rate(vllm:request_success_total[1m]))",
          "legendFormat": "Throughput (req/s)"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Throughput (tok/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "amp" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "amp" },
          "expr": "sum by (pod) (rate(vllm:generation_tokens_total[1m]))",
          "legendFormat": "{{pod}}"
        }
      ]
    }
  ]
}
